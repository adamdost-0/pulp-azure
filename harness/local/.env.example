# Safe defaults for disposable local Pulp solution runs.
# Do not put real secrets in this file.

PULP_CONTAINER_RUNTIME=auto
PULP_IMAGE=pulp/pulp:3.21
PULP_PULL_POLICY=missing

PULP_SCHEME=http
PULP_HOST=localhost
PULP_HTTP_HOST_PORT=18080
PULP_CONTAINER_HTTP_PORT=80

PULP_STORAGE_ROOT=/home/adamdost/synology/appconfig/pulp-azure
PULP_SESSION_ROOT=/home/adamdost/synology/appconfig/pulp-azure/pulp-sessions
PULP_SESSION_ID=local-apt-smoke
PULP_UPSTREAM_PORT=18081

PULP_APT_CLIENT_IMAGE=debian:bookworm-slim
PULP_APT_CLIENT_PULL_POLICY=missing
PULP_CLEANUP_IMAGE=busybox:1.36

PULP_SOLUTION_FILE=solutions/local-apt-smoke.json
PULP_EVIDENCE_ROOT=evidence
