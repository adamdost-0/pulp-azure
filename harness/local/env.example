# Copy to .env and replace placeholder values with internal/private mirror references.
# Do not commit .env.

# Pulp images may need amd64 on arm64 development hosts. Support services can
# run native to avoid QEMU issues.
PULP_PLATFORM=linux/amd64
SUPPORT_PLATFORM=linux/arm64
APT_CLIENT_PLATFORM=linux/amd64

# Required images. Use private/internal registry references for repeatable air-gapped work.
# PULP_SINGLE_IMAGE is preferred for the default single-container quickstart path.
PULP_SINGLE_IMAGE=<internal-acr-or-registry>/pulp:<tag>@sha256:<digest>
PULP_IMAGE=<internal-acr-or-registry>/pulp-minimal:<tag>@sha256:<digest>
PULP_WEB_IMAGE=<internal-acr-or-registry>/pulp-web:<tag>@sha256:<digest>
POSTGRES_IMAGE=<internal-acr-or-registry>/postgres:16@sha256:<digest>
REDIS_IMAGE=<internal-acr-or-registry>/redis:<tag>@sha256:<digest>
APT_CLIENT_IMAGE=<internal-acr-or-registry>/ubuntu:22.04@sha256:<digest>

# Optional port overrides for side-by-side low/high local stacks.
PULP_HTTP_PORT=18080

# Single-container defaults. Override for connected local testing only; committed
# defaults intentionally avoid public registry references.
PULP_CONTAINER_RUNTIME=podman
PULP_CONTAINER_NAME=pulp
PULP_SINGLE_WORKDIR=.work/single-container
PULP_ADMIN_PASSWORD=password
PULP_E2E_MODE=single
PULP_PULL_POLICY=never
