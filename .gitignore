# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Python test/runtime state
__pycache__/
*.pyc
.coverage
.mypy_cache/
.pytest_cache/
.ruff_cache/
coverage.xml
htmlcov/
tests/.work/

# Local disposable Pulp sessions and tool environments
.runtime/
.venv/
.venv-pulp-cli/
